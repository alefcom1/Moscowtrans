#: inc/rpt-optin-form.php:450
msgid "Your Website Overview"
msgstr "Ikhtisar Situs Web Anda"

#: inc/rpt-optin-form.php:451
msgid ""
"Your Site URL, WordPress & PHP version, plugins & themes. This data lets us "
"make sure this plugin always stays compatible with the most popular plugins "
"and themes."
msgstr ""
"URL Situs Anda, versi WordPress & PHP, plugin & tema. Data ini memungkinkan "
"kami memastikan plugin ini selalu tetap kompatibel dengan plugin dan tema "
"yang paling populer."

#: inc/rpt-optin-form.php:453
msgid "Your Profile Overview"
msgstr "Ikhtisar Profil Anda"

#: inc/rpt-optin-form.php:454
msgid "Your name and email address."
msgstr "Nama dan alamat email Anda."

#: inc/rpt-optin-form.php:456
