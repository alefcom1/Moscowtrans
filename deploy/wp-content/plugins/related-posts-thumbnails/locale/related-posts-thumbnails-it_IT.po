#: inc/rpt-optin-form.php:451
msgid ""
"Your Site URL, WordPress & PHP version, plugins & themes. This data lets us "
"make sure this plugin always stays compatible with the most popular plugins "
"and themes."
msgstr ""
"URL del tuo sito, versione di WordPress & PHP, plugin & temi. Questi dati "
"ci consentono di assicurarci che questo plugin rimanga sempre compatibile "
"con i plugin e i temi più popolari."

