#: inc/rpt-optin-form.php:451
msgid ""
"Your Site URL, WordPress & PHP version, plugins & themes. This data lets us "
"make sure this plugin always stays compatible with the most popular plugins "
"and themes."
msgstr ""
"La URL de tu sitio, versión de WordPress & PHP, plugins y temas. Estos "
"datos nos permiten asegurarnos de que este plugin siempre sea compatible "
"con los plugins y temas más populares."

